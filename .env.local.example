# ============================================================
# BAJAWS — Variables de entorno
# Copia este archivo como .env.local y rellena los valores.
# NUNCA commitear .env.local con valores reales.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Estas dos son PÚBLICAS (prefijo NEXT_PUBLIC_): van al browser
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...tu_anon_key

# SERVICE ROLE KEY: solo servidor. NUNCA exponer al cliente.
# Si un archivo que la usa tiene "use client" → error de seguridad.
# Solo usar en: src/lib/supabase/admin.ts y route handlers.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...tu_service_role_key

# ── Seguridad ────────────────────────────────────────────────
# Secreto para hashear IPs antes de almacenarlas (SHA-256 + secret)
# Cualquier string aleatorio largo. Cambiar invalida hashes existentes.
IP_HASH_SECRET=cambia_esto_por_un_string_aleatorio_largo_32chars

# ── Supabase Google OAuth (configurar en Supabase Dashboard) ─
# 1. Dashboard → Authentication → Providers → Google → Enable
# 2. Crear credenciales OAuth en Google Cloud Console:
#    - Authorized redirect URI: https://TU_PROYECTO.supabase.co/auth/v1/callback
# 3. Pegar Client ID y Client Secret en Supabase Dashboard.
# 4. En Next.js NO se necesita poner las credenciales Google aquí;
#    Supabase las maneja internamente.
#
# Redirect después del login (configurar en Supabase Dashboard):
#   Site URL: https://bajaws.com.mx
#   Additional redirect URLs: http://localhost:3000
#
# Para iniciar login desde Next.js:
#   supabase.auth.signInWithOAuth({ provider: 'google',
#     options: { redirectTo: `${origin}/auth/callback` } })
